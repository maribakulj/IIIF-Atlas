{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignore": [
      "**/dist/**",
      "**/.wrangler/**",
      "**/node_modules/**",
      "**/coverage/**",
      "apps/extension/dist/**",
      "**/*.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noEmptyInterface": "off",
        "noExportsInTest": "off",
        "noMisleadingCharacterClass": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn",
        "useNamingConvention": "off",
        "useTemplate": "off",
        "noUnusedTemplateLiteral": "off"
      },
      "correctness": {
        "noUnusedImports": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn",
        "useOptionalChain": "warn",
        "useLiteralKeys": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "noLabelWithoutControl": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": { "enabled": true, "trailingCommas": "none" }
  }
}
