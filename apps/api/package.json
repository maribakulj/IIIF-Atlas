{
  "name": "@iiif-atlas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply iiif_atlas --local",
    "migrate:remote": "wrangler d1 migrations apply iiif_atlas --remote"
  },
  "dependencies": {
    "@iiif-atlas/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  }
}
